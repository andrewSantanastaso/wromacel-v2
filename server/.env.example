# Copy to .env and fill in. The server reads either DATABASE_URL or the PG* vars.

# Option A — single connection string (most managed hosts give you this)
# DATABASE_URL=postgres://user:password@host:5432/romansh
# PGSSL=true            # set true if your host requires SSL (most do)

# Option B — discrete local settings (used if DATABASE_URL is unset)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=romansh

# Server
PORT=3000

# Lock this to your site's origin in production, e.g. https://romansh.example.com
CORS_ORIGIN=*
